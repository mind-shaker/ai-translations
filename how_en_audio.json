      "start": "00:05:15,961",
      "end": "00:05:21,672",
      "start_seconds": 315.961,
      "end_seconds": 321.672,
      "text": "And not just any random reading, but reading exactly what you just worked with.",
      "audio_path": "audio/how_en_082.wav"
