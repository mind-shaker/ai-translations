    },
    {
      "index": 107,
      "start": "00:07:21,467",
      "end": "00:07:26,576",
      "start_seconds": 441.467,
      "end_seconds": 446.576,
      "text": "Again, through this button, we need to switch to conversation mode with it.",
      "audio_path": "audio/how_en_107.wav"
    },
    {
      "index": 108,
      "start": "00:07:26,596",
      "end": "00:07:28,639",
      "start_seconds": 446.596,
      "end_seconds": 448.639,
      "text": "And what do we say?",
      "audio_path": "audio/how_en_108.wav"
    },
    {
      "index": 109,
      "start": "00:07:30,205",
      "end": "00:07:35,130",
      "start_seconds": 450.205,
      "end_seconds": 455.13,
      "text": "Let's create a simple dialogue in English for A1 level with you now.",
      "audio_path": "audio/how_en_109.wav"
