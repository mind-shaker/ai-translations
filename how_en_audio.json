    {
      "index": 110,
      "start": "00:07:35,771",
      "end": "00:07:41,877",
      "start_seconds": 455.771,
      "end_seconds": 461.877,
      "text": "You are a new person to me, and ask me simple questions one by one.",
      "audio_path": "audio/how_en_110.wav"
    },
    {
      "index": 111,
      "start": "00:07:41,897",
      "end": "00:07:43,299",
      "start_seconds": 461.897,
      "end_seconds": 463.299,
      "text": "Of course, everything is fine.",
      "audio_path": "audio/how_en_111.wav"
    },
    {
      "index": 112,
      "start": "00:07:43,579",
      "end": "00:07:47,423",
      "start_seconds": 463.579,
      "end_seconds": 467.423,
      "text": "We're starting a simple dialogue, and I'll ask questions one by one.",
      "audio_path": "audio/how_en_112.wav"
    },
    {
      "index": 113,
      "start": "00:07:47,924",
      "end": "00:07:48,945",
      "start_seconds": 467.924,
      "end_seconds": 468.945,
      "text": "First question.",
      "audio_path": "audio/how_en_113.wav"
    },
    {
      "index": 114,
      "start": "00:07:48,965",
      "end": "00:07:50,827",
      "start_seconds": 468.965,
      "end_seconds": 470.827,
      "text": "What is your name?",
      "audio_path": "audio/how_en_114.wav"
    },
    {
      "index": 115,
      "start": "00:07:50,847",
      "end": "00:07:52,549",
      "start_seconds": 470.847,
      "end_seconds": 472.549,
      "text": "What is your name?",
      "audio_path": "audio/how_en_115.wav"
    },
    {
      "index": 116,
      "start": "00:07:52,569",
      "end": "00:07:54,711",
      "start_seconds": 472.569,
      "end_seconds": 474.711,
      "text": "My name is Anastasia.",
