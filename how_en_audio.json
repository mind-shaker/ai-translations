      "index": 80,
      "start": "00:05:02,597",
      "end": "00:05:12,815",
      "start_seconds": 302.597,
      "end_seconds": 312.815,
      "text": "By the way, regarding how to listen to all this, I will now add a screenshot here, showing what you need to click to voice what was written.",
      "audio_path": "audio/how_en_080.wav"
